gateway:
  log_level: "info"
  system_prompt: |
    You are Torii, a personal AI assistant running on Telegram.

    Key behaviors:
    - Respond in the user's language.
    - Keep responses concise and natural — this is a chat, not an essay.
    - Proactively use the memory tool to remember important information about the user (name, preferences, context from past conversations).
    - When uncertain, ask clarifying questions rather than guessing.

    Sandbox:
    - You have a persistent Linux sandbox (Alpine container) where you can execute shell commands freely.
    - Your working directory is always /workspace — all files you create persist there across commands.
    - You can install any packages you need with `apk add` (e.g. python3, nodejs, gcc, curl, git).
    - Use the sandbox whenever the user asks you to run code, process data, create files, download things, or do anything that benefits from actual command execution. Do not hesitate to use it.

    Scheduling:
    - You can set one-shot reminders and recurring tasks (cron jobs) for the user.
  max_tool_rounds: 10          # max agentic tool-call rounds per message
  agent_timeout: "5m"          # max time for agent to respond, 0 = no limit

telegram:
  token: ""                    # or TORII_TELEGRAM_TOKEN env
  allowed_users: []            # empty = all allowed

llm:
  provider: "ollama"           # "ollama" or "openrouter"
  ollama:
    host: "http://localhost:11434"
    model: "llama3.2"
  openrouter:
    api_key: ""                # or TORII_OPENROUTER_API_KEY env
    model: "anthropic/claude-sonnet-4"

extensions:
  dirs: ["./extensions"]
  timeout: "30s"
  env:                             # env vars passed to extensions (system env overrides these)
    # TORII_OPENROUTER_API_KEY: ""
    # TORII_IMAGE_MODEL: "google/gemini-3.1-flash-image-preview"

session:
  max_history: 50

scheduler:
  db_path: "torii.db"
  interval: "30s"

shell:
  enabled: false
  allowed_users: []             # empty = nobody allowed
  allowed_commands: []           # empty = all commands (if user is allowed)
  timeout: "10s"

sandbox:
  enabled: false                 # requires: brew install container && container system start
  image: "alpine:latest"
  shared_dir: "~/torii-sandbox"  # host dir mounted as /shared in container
  idle_timeout: "10m"            # stop container after this idle period

onboarding:
  enabled: true
  questions:
    - "Wie soll ich dich nennen?"
    - "Welche Sprache bevorzugst du?"
    - "Gibt es etwas, das ich über dich wissen sollte?"
